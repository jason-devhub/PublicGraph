# Force LF line endings for all text files
* text=auto eol=lf

# Explicitly declare text files
*.php text eol=lf
*.twig text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.sh text eol=lf
.env.example text eol=lf
*.env text eol=lf
Makefile text eol=lf
Dockerfile* text eol=lf
docker/nginx*.conf text eol=lf

# Binary files — do not touch line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary
*.zip binary
*.gz binary
*.tar binary
