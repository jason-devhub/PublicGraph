{% extends 'base.html.twig' %}
{% import 'catalog/_macros.html.twig' as catalog %}

{% block title %}Accueil — PublicGraph{% endblock %}

{% block body %}
    <div class="border-b border-rule-strong pb-10">
        <p class="font-sans text-xs font-semibold uppercase tracking-wider text-text-tertiary">Consultation publique</p>
        <h1 class="mt-3 font-serif text-3xl font-medium tracking-tight text-text-primary md:text-4xl md:leading-tight">
            Cartographie d’influence des acteurs publics et privés
        </h1>
        <p class="mt-5 max-w-2xl font-sans text-base leading-relaxed text-text-secondary">
            PublicGraph recense des appartenances factuelles et sourcées à des organisations d’influence, des mandats et des trajectoires public-privé. Les fiches publiées ont été validées par modération.
        </p>
        <div class="mt-8 flex flex-wrap gap-4 font-sans text-sm">
            <a href="{{ path('app_person_index') }}" class="border border-accent bg-accent px-4 py-2 font-medium text-text-inverse no-underline hover:bg-accent-hover">Personnes</a>
            <a href="{{ path('app_graph_index') }}" class="border border-rule-strong px-4 py-2 text-text-primary no-underline hover:border-accent hover:text-accent">Graphe</a>
            <a href="{{ path('app_a_propos') }}" class="border border-rule-medium px-4 py-2 text-text-secondary no-underline hover:border-accent hover:text-text-primary">À propos</a>
            <a href="{{ path('app_register') }}" class="border border-rule-medium px-4 py-2 text-accent no-underline hover:border-accent">Contribuer</a>
        </div>
    </div>

    <section class="mt-12 border-t border-rule-medium pt-10" aria-labelledby="home-stats-heading">
        <h2 id="home-stats-heading" class="font-serif text-xl font-medium text-text-primary">Données publiées</h2>
        <p class="mt-2 font-sans text-sm text-text-secondary">Totaux mis en cache une heure (compteurs), listes actualisées à chaque chargement.</p>
        <dl class="mt-8 grid gap-6 border-t border-rule-subtle pt-8 sm:grid-cols-3">
            <div class="border-l-2 border-accent pl-4">
                <dt class="font-sans text-xs font-semibold uppercase tracking-wide text-text-tertiary">Personnes</dt>
                <dd class="mt-1 font-mono text-2xl tabular-nums text-text-primary" data-testid="home-stat-persons">{{ counts.persons }}</dd>
            </div>
            <div class="border-l-2 border-rule-medium pl-4">
                <dt class="font-sans text-xs font-semibold uppercase tracking-wide text-text-tertiary">Organisations</dt>
                <dd class="mt-1 font-mono text-2xl tabular-nums text-text-primary" data-testid="home-stat-organizations">{{ counts.organizations }}</dd>
            </div>
            <div class="border-l-2 border-rule-medium pl-4">
                <dt class="font-sans text-xs font-semibold uppercase tracking-wide text-text-tertiary">Portes tournantes</dt>
                <dd class="mt-1 font-mono text-2xl tabular-nums text-text-primary" data-testid="home-stat-doors">{{ counts.revolving_doors }}</dd>
            </div>
        </dl>
    </section>

    <section class="mt-14 border-t border-rule-medium pt-10" aria-labelledby="home-recent-persons-heading">
        <div class="flex flex-col gap-2 border-b border-rule-subtle pb-4 md:flex-row md:items-end md:justify-between">
            <h2 id="home-recent-persons-heading" class="font-serif text-xl font-medium text-text-primary">Fiches récentes</h2>
            <a href="{{ path('app_person_index') }}" class="font-sans text-sm text-accent no-underline hover:underline">Voir toutes les personnes</a>
        </div>
        <ul class="mt-6 divide-y divide-rule-subtle font-sans text-sm">
            {% for person in recentPersons %}
                <li class="flex flex-wrap items-baseline justify-between gap-2 py-4">
                    <span class="font-medium text-text-primary">
                        {% if person.slug %}
                            <a href="{{ path('app_person_show', {slug: person.slug}) }}" class="text-accent no-underline hover:underline">{{ catalog.full_name(person) }}</a>
                        {% else %}
                            {{ catalog.full_name(person) }}
                        {% endif %}
                    </span>
                    <span class="font-mono text-xs text-text-tertiary">{{ person.createdAt|date('d/m/Y') }}</span>
                </li>
            {% else %}
                <li class="py-6 text-text-secondary">Aucune fiche publiée pour le moment.</li>
            {% endfor %}
        </ul>
    </section>

    <section class="mt-14 border-t border-rule-medium pt-10" aria-labelledby="home-doors-heading">
        <div class="flex flex-col gap-2 border-b border-rule-subtle pb-4 md:flex-row md:items-end md:justify-between">
            <h2 id="home-doors-heading" class="font-serif text-xl font-medium text-text-primary">Portes tournantes notables</h2>
            <span class="font-sans text-xs text-text-tertiary">Les plus récemment publiées</span>
        </div>
        <ul class="mt-6 divide-y divide-rule-subtle font-sans text-sm">
            {% for door in recentDoors %}
                {% set person = door.person %}
                <li class="py-4">
                    {% if door.id and person %}
                        <a href="{{ path('app_revolving_door_show', {id: door.id}) }}" class="font-medium text-accent no-underline hover:underline">
                            {{ person.givenName }} {{ person.familyName }}
                        </a>
                        <p class="mt-1 text-text-secondary">
                            {% if door.sourcePosition and door.targetPosition
                                and door.sourcePosition.organization and door.targetPosition.organization %}
                                {{ door.sourcePosition|localized_position_title }} ({{ door.sourcePosition.organization|localized_organization_name }})
                                →
                                {{ door.targetPosition|localized_position_title }} ({{ door.targetPosition.organization|localized_organization_name }})
                            {% endif %}
                        </p>
                    {% endif %}
                </li>
            {% else %}
                <li class="py-6 text-text-secondary">Aucune porte tournante publiée pour le moment.</li>
            {% endfor %}
        </ul>
    </section>
{% endblock %}
