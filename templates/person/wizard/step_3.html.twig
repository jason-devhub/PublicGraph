{% extends 'base.html.twig' %}

{% block title %}Étape 3 — Mandats{% endblock %}

{% block body %}
    <div class="mx-auto max-w-xl px-4 py-10 font-sans text-sm">
        <p class="font-mono text-xs text-text-tertiary">Étape 3 / 5</p>
        <h1 class="mt-2 font-serif text-2xl text-text-primary">Poste principal (optionnel)</h1>
        <form method="post" class="mt-6 space-y-4">
            <input type="hidden" name="_token" value="{{ csrf_token('wizard_step') }}">
            <div>
                <label class="block text-text-secondary">Organisation</label>
                <select name="wizard[step3][organizationId]" class="mt-1 w-full border border-rule-medium px-3 py-2">
                    <option value="">—</option>
                    {% for org in organizationsSample %}
                        <option value="{{ org.id }}" {% if data.organizationId|default('') == org.id %}selected{% endif %}>{{ org.officialName }}</option>
                    {% endfor %}
                </select>
            </div>
            <div>
                <label class="block text-text-secondary">Titre</label>
                <input name="wizard[step3][titleFr]" value="{{ data.titleFr|default('') }}" class="mt-1 w-full border border-rule-medium px-3 py-2">
            </div>
            <div>
                <label class="block text-text-secondary">Nature</label>
                <select name="wizard[step3][nature]" class="mt-1 w-full border border-rule-medium px-3 py-2">
                    {% for n in ['elected_office','appointed_office','corporate_position','board_member','advisor','other'] %}
                        <option value="{{ n }}" {% if data.nature|default('other') == n %}selected{% endif %}>{{ n }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="grid gap-4 sm:grid-cols-2">
                <div>
                    <label class="block text-text-secondary">Début</label>
                    <input type="date" name="wizard[step3][startDate]" value="{{ data.startDate|default('') }}" class="mt-1 w-full border border-rule-medium px-3 py-2">
                </div>
                <div>
                    <label class="block text-text-secondary">Fin</label>
                    <input type="date" name="wizard[step3][endDate]" value="{{ data.endDate|default('') }}" class="mt-1 w-full border border-rule-medium px-3 py-2">
                </div>
            </div>
            <div>
                <label class="block text-text-secondary">Source URL (recommandé si poste renseigné)</label>
                <input type="url" name="wizard[step3][sourceUrl]" value="{{ data.sourceUrl|default('') }}" class="mt-1 w-full border border-rule-medium px-3 py-2" placeholder="https://…">
            </div>
            <button type="submit" class="border border-accent bg-accent px-4 py-2 font-medium text-text-inverse hover:bg-accent-hover">Continuer</button>
        </form>
    </div>
{% endblock %}
