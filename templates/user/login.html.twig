{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
    <h1>Connexion</h1>
    {% if error %}
        <p>{{ error.messageKey|trans(error.messageData, 'security') }}</p>
    {% endif %}
    <form method="post" action="{{ path('app_login') }}">
        <label for="_username">E-mail</label>
        <input type="email" value="{{ last_username }}" name="_username" id="_username" required autofocus>
        <label for="_password">Mot de passe</label>
        <input type="password" name="_password" id="_password" required>
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
        <button type="submit">Se connecter</button>
    </form>
    <p><a href="{{ path('app_register') }}">Créer un compte</a></p>
{% endblock %}
