{% import 'catalog/_macros.html.twig' as catalog %}

{# Panneau type catalogue (colonne étroite, facettes listées) — tokens design.md #}
{% set filter_label = 'mb-2 block font-sans text-[11px] font-semibold uppercase tracking-wider text-text-secondary' %}
{% set ts_skin = '[&_.ts-wrapper]:w-full [&_.ts-control]:rounded-xs [&_.ts-control]:border [&_.ts-control]:border-rule-medium [&_.ts-control]:bg-surface-primary [&_.ts-control]:min-h-[2.625rem] [&_.ts-control]:px-3 [&_.ts-control]:py-2 [&_.ts-control]:font-sans [&_.ts-control]:text-sm [&_.ts-control]:text-text-primary [&_.ts-control]:shadow-none [&_.ts-dropdown]:border [&_.ts-dropdown]:border-rule-medium [&_.ts-dropdown]:bg-surface-primary' %}

<div {{ attributes.defaults({class: 'person-catalog-filters'}) }}>
    <div class="flex flex-col gap-10 lg:grid lg:grid-cols-[minmax(0,17.5rem)_1fr] lg:items-start lg:gap-x-12">
        <aside
            class="border border-rule-medium bg-surface-secondary lg:sticky lg:top-6 lg:max-h-[calc(100vh-5rem)] lg:overflow-y-auto lg:self-start"
            data-catalog="person-filters"
            aria-labelledby="person-catalog-filters-heading"
        >
            <div class="flex items-start justify-between gap-3 border-b border-rule-medium px-5 py-4">
                <h2 id="person-catalog-filters-heading" class="font-serif text-xl font-medium tracking-tight text-text-primary">
                    {{ 'catalog.person_index.heading'|trans }}
                </h2>
                <a
                    href="{{ path('app_person_index') }}"
                    class="shrink-0 whitespace-nowrap border border-transparent pt-0.5 font-sans text-xs text-accent underline decoration-rule-medium underline-offset-4 hover:text-accent-hover hover:decoration-accent"
                >
                    {{ 'catalog.person_index.clear'|trans }}
                </a>
            </div>

            {{ form_start(form, {
                attr: {
                    'data-model': 'defer',
                    'data-action': 'change->live#update',
                    class: 'divide-y divide-rule-subtle px-5 py-1 font-sans text-sm text-text-primary',
                }
            }) }}

            <div class="py-5">
                <h3 class="font-serif text-base font-medium text-text-primary">{{ 'catalog.person_index.section_links'|trans }}</h3>
                <div class="mt-4 space-y-4">
                    <div class="{{ ts_skin }}">
                        {{ form_row(form.countries, { label_attr: { class: filter_label } }) }}
                    </div>
                    <div class="{{ ts_skin }}">
                        {{ form_row(form.organization, { label_attr: { class: filter_label } }) }}
                    </div>
                    <div class="{{ ts_skin }}">
                        {{ form_row(form.party, { label_attr: { class: filter_label } }) }}
                    </div>
                </div>
            </div>

            <div class="py-5">
                <h3 class="font-serif text-base font-medium text-text-primary">{{ 'catalog.person_index.section_period'|trans }}</h3>
                <div class="mt-4 space-y-4">
                    <div class="border border-rule-subtle bg-surface-primary px-3 py-3">
                        {{ form_row(form.filterYear, {
                            row_attr: { class: 'flex flex-row-reverse items-start gap-3 border border-rule-subtle bg-surface-primary px-3 py-3' },
                            label_attr: { class: 'grow pt-0.5 font-sans text-sm leading-snug text-text-secondary' },
                            attr: { class: 'mt-1 size-4 shrink-0 accent-accent' },
                        }) }}
                    </div>
                    <div class="grid grid-cols-2 gap-3">
                        {{ form_row(form.yearMin, { label_attr: { class: filter_label } }) }}
                        {{ form_row(form.yearMax, { label_attr: { class: filter_label } }) }}
                    </div>
                </div>
            </div>

            <div class="py-5">
                <h3 class="font-serif text-base font-medium text-text-primary">{{ 'catalog.person_index.section_status'|trans }}</h3>
                <div class="mt-4 space-y-3">
                    {{ form_row(form.aliveOnly, {
                        row_attr: { class: 'flex flex-row-reverse items-start gap-3 border border-rule-subtle bg-surface-primary px-3 py-2.5' },
                        label_attr: { class: 'grow pt-0.5 font-sans text-sm leading-snug text-text-secondary' },
                        attr: { class: 'mt-1 size-4 shrink-0 accent-accent' },
                    }) }}
                    {{ form_row(form.activeOnly, {
                        row_attr: { class: 'flex flex-row-reverse items-start gap-3 border border-rule-subtle bg-surface-primary px-3 py-2.5' },
                        label_attr: { class: 'grow pt-0.5 font-sans text-sm leading-snug text-text-secondary' },
                        attr: { class: 'mt-1 size-4 shrink-0 accent-accent' },
                    }) }}
                </div>
            </div>

            <div class="py-5">
                <h3 class="font-serif text-base font-medium text-text-primary">{{ 'catalog.person_index.section_categories'|trans }}</h3>
                <div class="mt-4 border border-rule-subtle bg-surface-primary">
                    <ul class="divide-y divide-rule-subtle" role="list">
                        {% for child in form.roleCategories %}
                            <li>
                                <label class="flex cursor-pointer items-start gap-3 px-3 py-2.5 hover:bg-surface-secondary">
                                    {{ form_widget(child, { attr: { class: 'mt-1 size-4 shrink-0 accent-accent' } }) }}
                                    <span class="font-sans text-sm leading-snug text-text-secondary">{{ child.vars.label }}</span>
                                </label>
                            </li>
                        {% endfor %}
                    </ul>
                    {{ form_errors(form.roleCategories) }}
                    {% do form.roleCategories.setRendered() %}
                </div>
            </div>

            <div class="py-5">
                <h3 class="font-serif text-base font-medium text-text-primary">{{ 'catalog.person_index.section_sort'|trans }}</h3>
                <div class="mt-4">
                    {{ form_row(form.sort, { label_attr: { class: filter_label } }) }}
                </div>
            </div>

            {{ form_end(form) }}
        </aside>

        {% set pc = personCatalog %}
        {% set pager = pc.pager %}
        {% set topOrgsByPerson = pc.topOrgsByPerson %}

        <div class="min-w-0">
            <p class="border-b border-rule-medium pb-3 font-sans text-sm text-text-secondary">
                {{ 'site.search_page.results_count'|trans({ '%count%': pager.nbResults }) }}
            </p>

            <div class="hidden md:block overflow-x-auto">
                <table class="mt-6 w-full border-collapse font-sans text-sm text-text-primary">
                    <thead>
                    <tr class="border-b border-rule-medium text-left text-xs font-semibold uppercase tracking-wide text-text-tertiary">
                        <th class="py-3 pr-4 font-medium" scope="col">Photo</th>
                        <th class="py-3 pr-4 font-medium" scope="col">Nom</th>
                        <th class="py-3 pr-4 font-medium" scope="col">Catégories</th>
                        <th class="py-3 pr-4 font-medium" scope="col">Pays</th>
                        <th class="py-3 font-medium" scope="col">Réseaux</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for person in pager.currentPageResults %}
                        {% set pid = person.id %}
                        <tr class="border-b border-rule-subtle">
                            <td class="py-3 pr-4 align-top">
                                {% if person.photoUrl %}
                                    <img src="{{ person.photoUrl }}" alt="" class="h-12 w-12 border border-rule-medium object-cover" loading="lazy" width="48" height="48">
                                {% else %}
                                    <div class="flex h-12 w-12 items-center justify-center border border-rule-medium bg-surface-inset font-mono text-xs text-text-tertiary" aria-hidden="true">?</div>
                                {% endif %}
                            </td>
                            <td class="py-3 pr-4 align-top">
                                {% if person.slug %}
                                    <a href="{{ path('app_person_show', {slug: person.slug}) }}" class="font-medium text-accent no-underline hover:text-accent-hover hover:underline">
                                        {{ catalog.full_name(person) }}
                                    </a>
                                {% else %}
                                    <span class="font-medium text-text-primary">{{ catalog.full_name(person) }}</span>
                                {% endif %}
                            </td>
                            <td class="py-3 pr-4 align-top">
                                <div class="flex flex-wrap gap-1">
                                    {% for cat in person.roleCategories %}
                                        <span class="inline-block rounded-xs px-2 py-0.5 text-[11px] font-semibold uppercase tracking-wide {{ catalog.role_category_classes(cat) }}">{{ catalog.role_category_label(cat) }}</span>
                                    {% else %}
                                        <span class="text-text-tertiary">—</span>
                                    {% endfor %}
                                </div>
                            </td>
                            <td class="py-3 pr-4 align-top">
                                <div class="flex flex-wrap items-center gap-1">
                                    {% for c in person.nationalities %}
                                        <span class="inline-flex items-center gap-1 font-mono text-xs text-text-secondary" title="{{ c.localizedName(app.request.locale) }}">
                                            <span class="select-none text-[10px] text-text-tertiary" aria-hidden="true">{{ c.isoCode }}</span>
                                            {{ c.isoCode }}
                                        </span>
                                    {% else %}
                                        <span class="text-text-tertiary">—</span>
                                    {% endfor %}
                                </div>
                            </td>
                            <td class="py-3 align-top">
                                <div class="flex flex-wrap gap-1">
                                    {% if pid and topOrgsByPerson[pid] is defined %}
                                        {% for org in topOrgsByPerson[pid] %}
                                            {% if org.slug %}
                                                <a href="{{ path('app_organization_show', {slug: org.slug}) }}" class="inline-block max-w-[10rem] truncate border border-rule-medium bg-surface-secondary px-2 py-0.5 text-xs text-text-secondary no-underline hover:border-accent hover:text-text-primary">{{ org.officialName }}</a>
                                            {% else %}
                                                <span class="inline-block max-w-[10rem] truncate border border-rule-medium px-2 py-0.5 text-xs text-text-tertiary">{{ org.officialName }}</span>
                                            {% endif %}
                                        {% endfor %}
                                    {% else %}
                                        <span class="text-text-tertiary">—</span>
                                    {% endif %}
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="py-8 text-center text-text-secondary">Aucun résultat.</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>

            <div class="mt-6 space-y-0 divide-y divide-rule-subtle border-t border-b border-rule-medium md:hidden">
                {% for person in pager.currentPageResults %}
                    {% set pid = person.id %}
                    <article class="bg-surface-primary py-4">
                        <div class="flex gap-3">
                            {% if person.photoUrl %}
                                <img src="{{ person.photoUrl }}" alt="" class="h-16 w-16 shrink-0 border border-rule-medium object-cover" loading="lazy" width="64" height="64">
                            {% else %}
                                <div class="flex h-16 w-16 shrink-0 items-center justify-center border border-rule-medium bg-surface-inset font-mono text-sm text-text-tertiary">?</div>
                            {% endif %}
                            <div class="min-w-0 flex-1">
                                <h3 class="font-serif text-lg font-medium text-text-primary">
                                    {% if person.slug %}
                                        <a href="{{ path('app_person_show', {slug: person.slug}) }}" class="text-accent no-underline hover:text-accent-hover hover:underline">{{ catalog.full_name(person) }}</a>
                                    {% else %}
                                        {{ catalog.full_name(person) }}
                                    {% endif %}
                                </h3>
                                <div class="mt-2 flex flex-wrap gap-1">
                                    {% for cat in person.roleCategories %}
                                        <span class="inline-block rounded-xs px-2 py-0.5 text-[11px] font-semibold uppercase tracking-wide {{ catalog.role_category_classes(cat) }}">{{ catalog.role_category_label(cat) }}</span>
                                    {% endfor %}
                                </div>
                                <div class="mt-2 flex flex-wrap gap-2 font-mono text-xs text-text-secondary">
                                    {% for c in person.nationalities %}
                                        <span class="inline-flex items-center gap-1">
                                            <span class="font-mono text-[10px] text-text-tertiary" aria-hidden="true">{{ c.isoCode }}</span>
                                            {{ c.isoCode }}
                                        </span>
                                    {% endfor %}
                                </div>
                                {% if pid and topOrgsByPerson[pid] is defined %}
                                    <div class="mt-3 flex flex-wrap gap-1">
                                        {% for org in topOrgsByPerson[pid] %}
                                            {% if org.slug %}
                                                <a href="{{ path('app_organization_show', {slug: org.slug}) }}" class="inline-block border border-rule-medium px-2 py-0.5 text-xs text-text-secondary no-underline hover:border-accent">{{ org.officialName }}</a>
                                            {% else %}
                                                <span class="inline-block border border-rule-medium px-2 py-0.5 text-xs text-text-tertiary">{{ org.officialName }}</span>
                                            {% endif %}
                                        {% endfor %}
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    </article>
                {% else %}
                    <p class="py-8 text-center text-text-secondary">Aucun résultat.</p>
                {% endfor %}
            </div>

            {% if pager.nbPages > 1 %}
                <nav class="mt-8 flex flex-wrap items-center justify-between gap-4 border-t border-rule-medium pt-6 font-sans text-sm" aria-label="{{ 'site.search_page.pagination_persons_aria'|trans }}">
                    <p class="text-text-secondary">{{ 'site.search_page.page_of'|trans({ '%page%': pager.currentPage, '%pages%': pager.nbPages }) }}</p>
                    <div class="flex gap-2">
                        {% if pager.hasPreviousPage %}
                            <button type="button"
                                    class="border border-rule-medium bg-surface-primary px-3 py-2 text-text-primary hover:bg-surface-secondary"
                                    data-action="live#action"
                                    data-live-action-param="setPage"
                                    data-live-page-param="{{ pager.currentPage - 1 }}">{{ 'site.search_page.prev'|trans }}</button>
                        {% endif %}
                        {% if pager.hasNextPage %}
                            <button type="button"
                                    class="border border-rule-medium bg-surface-primary px-3 py-2 text-text-primary hover:bg-surface-secondary"
                                    data-action="live#action"
                                    data-live-action-param="setPage"
                                    data-live-page-param="{{ pager.currentPage + 1 }}">{{ 'site.search_page.next'|trans }}</button>
                        {% endif %}
                    </div>
                </nav>
            {% endif %}
        </div>
    </div>
</div>
