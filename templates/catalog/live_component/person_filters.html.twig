{% import 'catalog/_macros.html.twig' as catalog %}

<div {{ attributes.defaults({class: 'space-y-10'}) }}>
    <div class="border-b border-rule-medium pb-8">
        <h2 class="font-sans text-xs font-semibold uppercase tracking-wide text-text-tertiary">Filtres</h2>
        {{ form_start(form, {
            attr: {
                'data-model': 'defer',
                'data-action': 'change->live#update',
            }
        }) }}
        <div class="mt-4 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {{ form_row(form.countries) }}
            {{ form_row(form.organization) }}
            {{ form_row(form.party) }}
        </div>
        <div class="mt-4 grid gap-4 md:grid-cols-3">
            {{ form_row(form.filterYear) }}
            {{ form_row(form.yearMin) }}
            {{ form_row(form.yearMax) }}
        </div>
        <div class="mt-4 flex flex-wrap gap-6">
            {{ form_row(form.aliveOnly) }}
            {{ form_row(form.activeOnly) }}
            {{ form_row(form.sort) }}
        </div>
        <fieldset class="mt-4 border-t border-rule-subtle pt-4">
            <legend class="font-sans text-xs font-semibold uppercase tracking-wide text-text-tertiary">Catégories</legend>
            <div class="mt-3 flex flex-wrap gap-3">
                {% for child in form.roleCategories %}
                    <label class="inline-flex items-center gap-2 font-sans text-sm text-text-secondary">
                        {{ form_widget(child) }}
                        {{ child.vars.label }}
                    </label>
                {% endfor %}
            </div>
        </fieldset>
        {{ form_end(form) }}
    </div>

    {% set pc = personCatalog %}
    {% set pager = pc.pager %}
    {% set topOrgsByPerson = pc.topOrgsByPerson %}

    <div class="hidden md:block overflow-x-auto border-t border-rule-medium">
        <table class="w-full border-collapse font-sans text-sm text-text-primary">
            <thead>
            <tr class="border-b border-rule-medium text-left text-xs font-semibold uppercase tracking-wide text-text-tertiary">
                <th class="py-3 pr-4 font-medium" scope="col">Photo</th>
                <th class="py-3 pr-4 font-medium" scope="col">Nom</th>
                <th class="py-3 pr-4 font-medium" scope="col">Catégories</th>
                <th class="py-3 pr-4 font-medium" scope="col">Pays</th>
                <th class="py-3 font-medium" scope="col">Réseaux</th>
            </tr>
            </thead>
            <tbody>
            {% for person in pager.currentPageResults %}
                {% set pid = person.id %}
                <tr class="border-b border-rule-subtle">
                    <td class="py-3 pr-4 align-top">
                        {% if person.photoUrl %}
                            <img src="{{ person.photoUrl }}" alt="" class="h-12 w-12 border border-rule-medium object-cover" loading="lazy" width="48" height="48">
                        {% else %}
                            <div class="flex h-12 w-12 items-center justify-center border border-rule-medium bg-surface-inset font-mono text-xs text-text-tertiary" aria-hidden="true">?</div>
                        {% endif %}
                    </td>
                    <td class="py-3 pr-4 align-top">
                        {% if person.slug %}
                            <a href="{{ path('app_person_show', {slug: person.slug}) }}" class="font-medium text-accent no-underline hover:text-accent-hover hover:underline">
                                {{ catalog.full_name(person) }}
                            </a>
                        {% else %}
                            <span class="font-medium text-text-primary">{{ catalog.full_name(person) }}</span>
                        {% endif %}
                    </td>
                    <td class="py-3 pr-4 align-top">
                        <div class="flex flex-wrap gap-1">
                            {% for cat in person.roleCategories %}
                                <span class="inline-block rounded-xs px-2 py-0.5 text-[11px] font-semibold uppercase tracking-wide {{ catalog.role_category_classes(cat) }}">{{ catalog.role_category_label(cat) }}</span>
                            {% else %}
                                <span class="text-text-tertiary">—</span>
                            {% endfor %}
                        </div>
                    </td>
                    <td class="py-3 pr-4 align-top">
                        <div class="flex flex-wrap items-center gap-1">
                            {% for c in person.nationalities %}
                                <span class="inline-flex items-center gap-1 font-mono text-xs text-text-secondary" title="{{ c.localizedName(app.request.locale) }}">
                                    <span class="select-none text-[10px] text-text-tertiary" aria-hidden="true">{{ c.isoCode }}</span>
                                    {{ c.isoCode }}
                                </span>
                            {% else %}
                                <span class="text-text-tertiary">—</span>
                            {% endfor %}
                        </div>
                    </td>
                    <td class="py-3 align-top">
                        <div class="flex flex-wrap gap-1">
                            {% if pid and topOrgsByPerson[pid] is defined %}
                                {% for org in topOrgsByPerson[pid] %}
                                    {% if org.slug %}
                                        <a href="{{ path('app_organization_show', {slug: org.slug}) }}" class="inline-block max-w-[10rem] truncate border border-rule-medium bg-surface-secondary px-2 py-0.5 text-xs text-text-secondary no-underline hover:border-accent hover:text-text-primary">{{ org.officialName }}</a>
                                    {% else %}
                                        <span class="inline-block max-w-[10rem] truncate border border-rule-medium px-2 py-0.5 text-xs text-text-tertiary">{{ org.officialName }}</span>
                                    {% endif %}
                                {% endfor %}
                            {% else %}
                                <span class="text-text-tertiary">—</span>
                            {% endif %}
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5" class="py-8 text-center text-text-secondary">Aucun résultat.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    <div class="space-y-4 md:hidden">
        {% for person in pager.currentPageResults %}
            {% set pid = person.id %}
            <article class="border-t border-b border-rule-medium bg-surface-primary py-4">
                <div class="flex gap-3">
                    {% if person.photoUrl %}
                        <img src="{{ person.photoUrl }}" alt="" class="h-16 w-16 shrink-0 border border-rule-medium object-cover" loading="lazy" width="64" height="64">
                    {% else %}
                        <div class="flex h-16 w-16 shrink-0 items-center justify-center border border-rule-medium bg-surface-inset font-mono text-sm text-text-tertiary">?</div>
                    {% endif %}
                    <div class="min-w-0 flex-1">
                        <h3 class="font-serif text-lg font-medium text-text-primary">
                            {% if person.slug %}
                                <a href="{{ path('app_person_show', {slug: person.slug}) }}" class="text-accent no-underline hover:text-accent-hover hover:underline">{{ catalog.full_name(person) }}</a>
                            {% else %}
                                {{ catalog.full_name(person) }}
                            {% endif %}
                        </h3>
                        <div class="mt-2 flex flex-wrap gap-1">
                            {% for cat in person.roleCategories %}
                                <span class="inline-block rounded-xs px-2 py-0.5 text-[11px] font-semibold uppercase tracking-wide {{ catalog.role_category_classes(cat) }}">{{ catalog.role_category_label(cat) }}</span>
                            {% endfor %}
                        </div>
                        <div class="mt-2 flex flex-wrap gap-2 font-mono text-xs text-text-secondary">
                            {% for c in person.nationalities %}
                                <span class="inline-flex items-center gap-1">
                                    <span class="font-mono text-[10px] text-text-tertiary" aria-hidden="true">{{ c.isoCode }}</span>
                                    {{ c.isoCode }}
                                </span>
                            {% endfor %}
                        </div>
                        {% if pid and topOrgsByPerson[pid] is defined %}
                            <div class="mt-3 flex flex-wrap gap-1">
                                {% for org in topOrgsByPerson[pid] %}
                                    {% if org.slug %}
                                        <a href="{{ path('app_organization_show', {slug: org.slug}) }}" class="inline-block border border-rule-medium px-2 py-0.5 text-xs text-text-secondary no-underline hover:border-accent">{{ org.officialName }}</a>
                                    {% else %}
                                        <span class="inline-block border border-rule-medium px-2 py-0.5 text-xs text-text-tertiary">{{ org.officialName }}</span>
                                    {% endif %}
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>
                </div>
            </article>
        {% else %}
            <p class="text-center text-text-secondary">Aucun résultat.</p>
        {% endfor %}
    </div>

    {% if pager.nbPages > 1 %}
        <nav class="flex flex-wrap items-center justify-between gap-4 border-t border-rule-medium pt-6 font-sans text-sm" aria-label="Pagination">
            <p class="text-text-secondary">Page {{ pager.currentPage }} / {{ pager.nbPages }}</p>
            <div class="flex gap-2">
                {% if pager.hasPreviousPage %}
                    <button type="button"
                            class="border border-rule-medium bg-surface-primary px-3 py-2 text-text-primary hover:bg-surface-secondary"
                            data-action="live#action"
                            data-live-action-param="setPage"
                            data-live-page-param="{{ pager.currentPage - 1 }}">Précédent</button>
                {% endif %}
                {% if pager.hasNextPage %}
                    <button type="button"
                            class="border border-rule-medium bg-surface-primary px-3 py-2 text-text-primary hover:bg-surface-secondary"
                            data-action="live#action"
                            data-live-action-param="setPage"
                            data-live-page-param="{{ pager.currentPage + 1 }}">Suivant</button>
                {% endif %}
            </div>
        </nav>
    {% endif %}
</div>
