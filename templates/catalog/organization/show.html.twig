{% extends 'base.html.twig' %}
{% import 'catalog/_macros.html.twig' as catalog %}

{% block head_seo %}
    {{ component('MetaTags', { entity: organization, type: 'organization', organizationMemberCount: organization_member_count }) }}
{% endblock %}

{% block body %}
    <article>
        {{ include('catalog/_share_toolbar.html.twig', {
            share_page_url: url('app_organization_show', { slug: organization.slug }),
            share_page_title: organization_display_name,
        }) }}
        <header class="border-b border-rule-strong pb-8">
            <div class="flex flex-wrap items-start justify-between gap-4">
                <div class="min-w-0">
                    <h1 class="font-serif text-3xl font-medium tracking-tight text-text-primary md:text-4xl">{{ organization_display_name }}</h1>
                    {% if organization_show_official_subtitle %}
                        <p class="mt-2 font-sans text-sm text-text-secondary">{{ 'org.official_name_label'|trans }} : {{ organization_official_name }}</p>
                    {% endif %}
                </div>
                <span class="shrink-0 rounded-xs px-2 py-1 text-[11px] font-semibold uppercase tracking-wide {{ catalog.organization_type_classes(organization.type) }}">{{ catalog.organization_type_label(organization.type) }}</span>
            </div>
            <div class="mt-4 flex flex-wrap gap-3 font-sans text-sm text-text-secondary">
                {% for c in organization.countries %}
                            <span class="inline-flex items-center gap-1 font-mono text-xs">
                                <span class="text-[10px] text-text-tertiary" aria-hidden="true">{{ c.isoCode }}</span>
                                {{ c.localizedName(app.request.locale) }}
                            </span>
                {% endfor %}
                {% if organization.foundedYear %}
                    <span>Fondée {{ organization.foundedYear }}{% if organization.dissolvedYear %} — Dissoute {{ organization.dissolvedYear }}{% endif %}</span>
                {% endif %}
                {% if organization.websiteUrl %}
                    <a href="{{ organization.websiteUrl }}" class="text-accent no-underline hover:underline" rel="noopener noreferrer">Site officiel</a>
                {% endif %}
            </div>
            {% if organization.type == 'political_party' and organization.partyDetails %}
                {% set party = organization.partyDetails %}
                <div class="mt-6 border-l-2 border-accent pl-4 font-sans text-sm text-text-primary">
                    <p><span class="text-text-secondary">Famille européenne :</span> {{ party.europeanFamily|default('—') }}</p>
                    {% if party.colorHex %}
                        <p class="mt-2 inline-flex items-center gap-2">
                            <span class="text-text-secondary">Couleur :</span>
                            <span class="inline-block h-4 w-8 rounded-sm border border-rule-medium shadow-subtle" style="background-color: {{ party.colorHex|e('html_attr') }};" title="{{ party.colorHex|e('html_attr') }}"></span>
                            <span class="font-mono text-xs">{{ party.colorHex }}</span>
                        </p>
                    {% endif %}
                </div>
            {% endif %}
        </header>

        <section class="mt-10 border-t border-rule-medium pt-8">
            <h2 class="font-serif text-2xl font-medium text-text-primary">Présentation</h2>
            {% if catalog_description %}
                <div class="mt-4 max-w-3xl font-sans text-base leading-relaxed text-text-primary">{{ catalog_description|nl2br }}</div>
            {% else %}
                <p class="mt-4 font-sans text-sm text-text-secondary">Pas de description pour cette organisation.</p>
            {% endif %}
        </section>

        <section class="mt-12 border-t border-rule-medium pt-8" aria-labelledby="org-mini-graph-heading">
            <h2 id="org-mini-graph-heading" class="font-serif text-2xl font-medium text-text-primary">Cartographie des membres</h2>
            <aside class="mt-6 overflow-hidden rounded-sm border border-[#2A3038] bg-ink text-ink-text shadow-[0_12px_40px_-12px_rgba(0,0,0,0.35)]">
                <header class="flex items-center justify-between gap-3 border-b border-[#2A3038] px-4 py-3 font-sans text-xs uppercase tracking-wider text-ink-secondary">
                    <span>Organisation et membres publiés</span>
                    <span data-mini-graph-target="count" class="tabular-nums">—</span>
                </header>
                <div
                    class="relative min-h-[360px] w-full"
                    data-controller="mini-graph"
                    data-mini-graph-url-value="{{ path('app_organization_graph_data', { slug: organization.slug }) }}"
                    data-mini-graph-focus-node-id-value="org-{{ organization.id }}"
                    data-mini-graph-locale-value="{{ app.request.locale }}"
                    data-mini-graph-msg-analyzing-value="{{ 'mini_graph.analyzing'|trans|e('html_attr') }}"
                    data-mini-graph-msg-load-error-value="{{ 'mini_graph.load_error'|trans|e('html_attr') }}"
                    data-mini-graph-msg-connections-zero-value="{{ 'mini_graph.org_members_zero'|trans|e('html_attr') }}"
                    data-mini-graph-msg-connections-one-value="{{ 'mini_graph.org_members_one'|trans|e('html_attr') }}"
                    data-mini-graph-msg-connections-many-value="{{ 'mini_graph.org_members_many'|trans|e('html_attr') }}"
                >
                    <div data-mini-graph-target="skeleton" class="absolute inset-0 flex items-center justify-center bg-ink font-sans text-sm text-ink-secondary motion-safe:animate-pulse" aria-hidden="true">Chargement du graphe…</div>
                    <div data-mini-graph-target="canvas" class="absolute inset-0 z-10 hidden h-full min-h-[360px] w-full bg-ink" role="img" aria-label="Graphe de l’organisation et de ses membres"></div>
                    <div data-mini-graph-target="analyzing" class="absolute inset-0 z-20 hidden items-center justify-center bg-ink px-6 text-center font-sans text-sm leading-relaxed text-ink-text" role="status"></div>
                </div>
                <footer class="border-t border-[#2A3038] px-4 py-3 font-sans text-sm">
                    <a href="{{ path('app_graph_index', { organization: organization.slug }) }}" class="text-ink-accent no-underline hover:underline">Voir dans le graphe complet ↗</a>
                </footer>
            </aside>
        </section>

        <section class="mt-12 border-t border-rule-medium pt-8">
            <h2 class="font-serif text-2xl font-medium text-text-primary">Membres et cadres connus</h2>
            <twig:CatalogOrganizationMembers :organization="organization" />
        </section>
    </article>
{% endblock %}
