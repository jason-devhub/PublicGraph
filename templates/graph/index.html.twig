{% extends 'base.html.twig' %}

{% block title %}{{ 'global_graph.heading'|trans }} — PublicGraph{% endblock %}

{% block main_container_class %}mx-auto flex w-full min-h-0 max-w-none flex-1 flex-col px-0 py-0{% endblock %}

{% set filter_label = 'mb-1.5 block font-sans text-[11px] font-semibold uppercase tracking-wider text-text-secondary' %}
{% set ts_skin = '[&_.ts-wrapper]:w-full [&_.ts-control]:rounded-xs [&_.ts-control]:border [&_.ts-control]:border-rule-medium [&_.ts-control]:bg-surface-primary [&_.ts-control]:min-h-[2.625rem] [&_.ts-control]:px-3 [&_.ts-control]:py-2 [&_.ts-control]:font-sans [&_.ts-control]:text-sm [&_.ts-control]:text-text-primary [&_.ts-control]:shadow-none [&_.ts-dropdown]:border [&_.ts-dropdown]:border-rule-medium [&_.ts-dropdown]:bg-surface-primary' %}

{% block body %}
    <div
        class="flex min-h-0 min-h-[calc(100dvh-5.5rem)] w-full min-w-0 flex-1 flex-col"
        data-controller="global-graph"
        data-global-graph-url-value="{{ path('app_api_graph_data') }}"
        data-global-graph-query-value="{{ app.request.queryString|e('html_attr') }}"
        data-global-graph-locale-value="{{ app.request.locale }}"
        data-global-graph-msg-loading-value="{{ 'global_graph.loading'|trans|e('html_attr') }}"
        data-global-graph-msg-error-value="{{ 'global_graph.error'|trans|e('html_attr') }}"
        data-global-graph-msg-view-full-value="{{ 'global_graph.view_full'|trans|e('html_attr') }}"
        data-global-graph-msg-kind-person-value="{{ 'global_graph.kind_person'|trans|e('html_attr') }}"
        data-global-graph-msg-kind-organization-value="{{ 'global_graph.kind_organization'|trans|e('html_attr') }}"
        data-global-graph-msg-label-category-value="{{ 'global_graph.label_category'|trans|e('html_attr') }}"
        data-global-graph-msg-label-countries-value="{{ 'global_graph.label_countries'|trans|e('html_attr') }}"
        data-global-graph-msg-label-org-type-value="{{ 'global_graph.label_org_type'|trans|e('html_attr') }}"
        data-global-graph-role-labels-value="{{ graph_role_labels_json|e('html_attr') }}"
        data-global-graph-org-type-labels-value="{{ graph_org_type_labels_json|e('html_attr') }}"
        data-global-graph-focus-slug-value="{{ focus_person is defined and focus_person and focus_person.slug ? focus_person.slug|e('html_attr') : '' }}"
    >
        <section class="shrink-0 border-b border-rule-medium bg-surface-secondary" aria-labelledby="global-graph-heading">
            <div class="flex flex-wrap items-center justify-between gap-3 border-b border-rule-medium px-4 py-3 sm:px-5">
                <h1 id="global-graph-heading" class="font-serif text-lg font-medium tracking-tight text-text-primary sm:text-xl">
                    {{ 'global_graph.heading'|trans }}
                </h1>
                <a
                    href="{{ path('app_graph_index') }}"
                    class="shrink-0 whitespace-nowrap font-sans text-xs text-accent underline decoration-rule-medium underline-offset-4 hover:text-accent-hover hover:decoration-accent"
                >
                    {{ 'global_graph.reset_filters'|trans }}
                </a>
            </div>

            {{ form_start(graph_filter_form, {
                action: path('app_graph_index'),
                attr: {
                    class: 'space-y-4 px-4 py-4 font-sans text-sm text-text-primary sm:space-y-5 sm:px-5 sm:py-5',
                    role: 'search',
                },
            }) }}
                {% if focus_person is defined and focus_person and focus_person.slug %}
                    <input type="hidden" name="focus" value="{{ focus_person.slug|e('html_attr') }}">
                {% endif %}
                <div class="flex flex-wrap items-end gap-x-4 gap-y-4 md:gap-x-5">
                    <div class="min-w-[min(100%,10rem)] flex-1 basis-[12rem] {{ ts_skin }}">
                        {{ form_row(graph_filter_form.organization, { label_attr: { class: filter_label } }) }}
                    </div>
                    <div class="min-w-[min(100%,10rem)] flex-1 basis-[14rem] {{ ts_skin }}">
                        {{ form_row(graph_filter_form.countries, { label_attr: { class: filter_label } }) }}
                    </div>
                    <div class="w-full min-w-0 shrink-0 sm:w-auto sm:min-w-[7rem]">
                        {{ form_row(graph_filter_form.yearMin, { label_attr: { class: filter_label } }) }}
                    </div>
                    <div class="w-full min-w-0 shrink-0 sm:w-auto sm:min-w-[7rem]">
                        {{ form_row(graph_filter_form.yearMax, { label_attr: { class: filter_label } }) }}
                    </div>
                    <div class="w-full min-w-0 shrink-0 sm:w-auto sm:min-w-[10rem]">
                        {{ form_row(graph_filter_form.colorMode, { label_attr: { class: filter_label } }) }}
                    </div>
                </div>

                <div class="border-t border-rule-subtle pt-4">
                    {{ form_label(graph_filter_form.categories, null, { label_attr: { class: filter_label } }) }}
                    <div class="mt-2 flex flex-wrap gap-x-4 gap-y-2">
                        {% for child in graph_filter_form.categories %}
                            <label class="inline-flex cursor-pointer items-center gap-2 border border-transparent py-0.5 font-sans text-xs text-text-secondary hover:text-text-primary">
                                {{ form_widget(child, { attr: { class: 'size-3.5 shrink-0 accent-accent' } }) }}
                                <span>{{ child.vars.label }}</span>
                            </label>
                        {% endfor %}
                    </div>
                    {{ form_errors(graph_filter_form.categories) }}
                    {% do graph_filter_form.categories.setRendered() %}
                </div>

                <div class="flex flex-wrap items-center gap-4 border-t border-rule-subtle pt-4">
                    {{ form_row(graph_filter_form.maxNodes, { label_attr: { class: filter_label ~ ' !mb-0' } }) }}
                    <div class="flex shrink-0 items-end pb-0.5">
                        <button type="submit" class="pg-btn-primary min-h-11 shrink-0 px-4 py-2 font-sans text-xs font-semibold uppercase tracking-wide no-underline">
                            {{ 'global_graph.apply'|trans }}
                        </button>
                    </div>
                </div>
            {{ form_end(graph_filter_form) }}
        </section>

        <div class="relative flex min-h-0 w-full flex-1 flex-col bg-ink">
            <div data-global-graph-target="toolbar" class="absolute left-3 top-3 z-20 flex max-w-[min(26rem,calc(100%-1.5rem))] flex-col gap-2 font-sans text-xs">
                <div class="flex flex-wrap gap-2">
                    <button type="button" data-action="global-graph#zoomIn" class="min-h-11 rounded-sm border border-[#2A3038] bg-ink px-3 py-2 text-ink-text shadow-btn-ink transition-shadow duration-150 hover:bg-[#2A3038] hover:shadow-btn-ink-hover">{{ 'global_graph.zoom_in'|trans }}</button>
                    <button type="button" data-action="global-graph#zoomOut" class="min-h-11 rounded-sm border border-[#2A3038] bg-ink px-3 py-2 text-ink-text shadow-btn-ink transition-shadow duration-150 hover:bg-[#2A3038] hover:shadow-btn-ink-hover">{{ 'global_graph.zoom_out'|trans }}</button>
                    <button type="button" data-action="global-graph#fit" class="min-h-11 rounded-sm border border-[#2A3038] bg-ink px-3 py-2 text-ink-text shadow-btn-ink transition-shadow duration-150 hover:bg-[#2A3038] hover:shadow-btn-ink-hover">{{ 'global_graph.fit'|trans }}</button>
                    <button type="button" data-action="global-graph#reset" class="min-h-11 rounded-sm border border-[#2A3038] bg-ink px-3 py-2 text-ink-text shadow-btn-ink transition-shadow duration-150 hover:bg-[#2A3038] hover:shadow-btn-ink-hover">{{ 'global_graph.reset_view'|trans }}</button>
                    <select data-global-graph-target="layoutSelect" data-action="change->global-graph#changeLayout" class="min-h-11 rounded-sm border border-[#2A3038] bg-ink px-3 py-2 text-ink-text shadow-btn-ink transition-shadow duration-150 hover:shadow-btn-ink-hover">
                        <option value="fcose">fcose</option>
                        <option value="cose">cose</option>
                        <option value="concentric">concentric</option>
                        <option value="breadthfirst">breadthfirst</option>
                    </select>
                </div>
                <p class="m-0 leading-snug text-[0.65rem] text-ink-secondary">{{ 'global_graph.zoom_hint'|trans }}</p>
            </div>

            <div class="relative min-h-0 w-full flex-1">
                <div class="pg-graph-viewport pg-graph-viewport--fill absolute inset-0">
                    <div data-global-graph-target="canvas" class="absolute inset-0 z-10" role="img" aria-label="{{ 'global_graph.heading'|trans }}"></div>
                    <div data-global-graph-target="status" class="absolute inset-0 z-0 flex items-center justify-center font-sans text-sm text-ink-secondary">{{ 'global_graph.loading'|trans }}</div>
                </div>
            </div>
        </div>

        <dialog
            data-global-graph-target="nodeDialog"
            class="w-[min(100%,26rem)] max-w-[calc(100vw-2rem)] border border-rule-medium bg-surface-primary p-0 font-sans text-sm text-text-primary shadow-modal backdrop:bg-[rgba(14,18,24,0.5)]"
            aria-labelledby="global-graph-dialog-title"
        >
            <div class="flex items-start justify-between gap-3 border-b border-rule-medium px-4 py-3 sm:px-5">
                <h2 id="global-graph-dialog-title" data-global-graph-target="dialogTitle" class="min-w-0 flex-1 font-serif text-lg font-medium leading-snug text-text-primary"></h2>
                <form method="dialog" class="shrink-0">
                    <button type="submit" class="pg-btn-outline min-h-11 px-3 py-2 font-sans text-xs font-semibold uppercase tracking-wide text-text-secondary">
                        {{ 'global_graph.close_modal'|trans }}
                    </button>
                </form>
            </div>
            <div class="space-y-2 px-4 py-4 sm:px-5 sm:py-5">
                <p data-global-graph-target="dialogKind" class="m-0 font-sans text-[11px] font-semibold uppercase tracking-wider text-text-tertiary"></p>
                <p data-global-graph-target="dialogLine1" class="m-0 leading-relaxed text-text-secondary"></p>
                <p data-global-graph-target="dialogLine2" class="m-0 hidden leading-relaxed text-text-secondary"></p>
                <a
                    data-global-graph-target="dialogLink"
                    href="#"
                    class="pg-btn-primary mt-4 inline-block min-h-11 px-4 py-2 font-sans text-xs font-semibold uppercase tracking-wide no-underline"
                >{{ 'global_graph.view_full'|trans }}</a>
            </div>
        </dialog>
    </div>
{% endblock %}
