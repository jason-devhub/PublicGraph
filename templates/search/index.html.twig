{% extends 'base.html.twig' %}

{% block title %}{{ 'site.search_page.meta_title'|trans }}{% if q %} — « {{ q }} »{% endif %} — PublicGraph{% endblock %}

{% block body %}
    <header class="border-b border-rule-medium pb-8">
        <h1 class="font-serif text-3xl text-text-primary md:text-4xl">{{ 'site.search_page.heading'|trans }}</h1>
        <form action="{{ path('app_search_index') }}" method="get" class="mt-6 flex flex-wrap gap-3 border-t border-rule-subtle pt-6">
            <label class="sr-only" for="search-page-q">{{ 'site.search_page.term_label'|trans }}</label>
            <input
                id="search-page-q"
                type="search"
                name="q"
                value="{{ q }}"
                placeholder="{{ 'site.search_page.input_placeholder'|trans }}"
                class="pg-input min-h-11 w-full min-w-0 flex-1 px-3 py-2 font-sans text-sm sm:min-w-[12rem]"
            />
            {% if type != 'all' %}
                <input type="hidden" name="type" value="{{ type }}" />
            {% endif %}
            <button type="submit" class="pg-btn-primary min-h-11 px-4 py-2 font-sans text-sm">
                {{ 'site.search_page.submit'|trans }}
            </button>
        </form>
    </header>

    {% if q is empty %}
        <p class="mt-8 font-sans text-sm text-text-secondary">{{ 'site.search_page.empty_hint'|trans }}</p>
    {% else %}
        <nav class="mt-8 flex flex-wrap gap-2 border-b border-rule-medium pb-3 font-sans text-sm" aria-label="{{ 'site.search_page.filter_nav_aria'|trans }}">
            <a href="{{ path('app_search_index', { q: q, type: 'all', pp: 1, op: 1 }) }}"
               class="{% if type == 'all' %}border-b-2 border-accent text-text-primary{% else %}text-text-secondary hover:text-text-primary{% endif %} px-2 py-1 no-underline">
                {{ 'site.search_page.filter_all'|trans }}
            </a>
            <a href="{{ path('app_search_index', { q: q, type: 'persons', page: type == 'persons' ? page : 1 }) }}"
               class="{% if type == 'persons' %}border-b-2 border-accent text-text-primary{% else %}text-text-secondary hover:text-text-primary{% endif %} px-2 py-1 no-underline">
                {{ 'site.search_page.filter_persons'|trans }}
            </a>
            <a href="{{ path('app_search_index', { q: q, type: 'organizations', page: type == 'organizations' ? page : 1 }) }}"
               class="{% if type == 'organizations' %}border-b-2 border-accent text-text-primary{% else %}text-text-secondary hover:text-text-primary{% endif %} px-2 py-1 no-underline">
                {{ 'site.search_page.filter_organizations'|trans }}
            </a>
        </nav>

        {% if type == 'all' %}
            <div class="mt-8 grid gap-10 lg:grid-cols-2">
                <section aria-labelledby="search-persons-heading">
                    <h2 id="search-persons-heading" class="font-serif text-lg text-text-primary">{{ 'site.search_page.persons'|trans }}</h2>
                    {% if personsResult %}
                        <p class="mt-1 font-sans text-xs text-text-tertiary">{{ 'site.search_page.results_count'|trans({ '%count%': personsResult.estimatedTotalHits ?? 0 }) }}</p>
                        <ul class="mt-4 divide-y divide-rule-subtle border-t border-rule-medium font-sans text-sm">
                            {% for hit in personsResult.hits %}
                                <li class="py-3">
                                    <a href="{{ path('app_person_show', { slug: hit.slug }) }}" class="text-text-primary no-underline hover:text-accent hover:underline">{{ hit.fullName }}</a>
                                </li>
                            {% else %}
                                <li class="py-3 text-text-secondary">{{ 'site.search_page.no_person'|trans }}</li>
                            {% endfor %}
                        </ul>
                        {% set totalP = personsResult.estimatedTotalHits ?? 0 %}
                        {% set pagesP = totalP > 0 ? ((totalP - 1) // perPage) + 1 : 1 %}
                        {% if pagesP > 1 %}
                            <nav class="mt-4 flex flex-wrap gap-2 font-sans text-xs text-text-secondary" aria-label="{{ 'site.search_page.pagination_persons_aria'|trans }}">
                                {% if pagePersons > 1 %}
                                    <a class="no-underline hover:text-text-primary hover:underline" href="{{ path('app_search_index', { q: q, type: 'all', pp: pagePersons - 1, op: pageOrgs }) }}">{{ 'site.search_page.prev'|trans }}</a>
                                {% endif %}
                                <span>{{ 'site.search_page.page_of'|trans({ '%page%': pagePersons, '%pages%': pagesP }) }}</span>
                                {% if pagePersons < pagesP %}
                                    <a class="no-underline hover:text-text-primary hover:underline" href="{{ path('app_search_index', { q: q, type: 'all', pp: pagePersons + 1, op: pageOrgs }) }}">{{ 'site.search_page.next'|trans }}</a>
                                {% endif %}
                            </nav>
                        {% endif %}
                    {% endif %}
                </section>
                <section aria-labelledby="search-orgs-heading">
                    <h2 id="search-orgs-heading" class="font-serif text-lg text-text-primary">{{ 'site.search_page.organizations'|trans }}</h2>
                    {% if organizationsResult %}
                        <p class="mt-1 font-sans text-xs text-text-tertiary">{{ 'site.search_page.results_count'|trans({ '%count%': organizationsResult.estimatedTotalHits ?? 0 }) }}</p>
                        <ul class="mt-4 divide-y divide-rule-subtle border-t border-rule-medium font-sans text-sm">
                            {% for hit in organizationsResult.hits %}
                                <li class="py-3">
                                    <a href="{{ path('app_organization_show', { slug: hit.slug }) }}" class="text-text-primary no-underline hover:text-accent hover:underline">{{ hit.officialName }}</a>
                                </li>
                            {% else %}
                                <li class="py-3 text-text-secondary">{{ 'site.search_page.no_organization'|trans }}</li>
                            {% endfor %}
                        </ul>
                        {% set totalO = organizationsResult.estimatedTotalHits ?? 0 %}
                        {% set pagesO = totalO > 0 ? ((totalO - 1) // perPage) + 1 : 1 %}
                        {% if pagesO > 1 %}
                            <nav class="mt-4 flex flex-wrap gap-2 font-sans text-xs text-text-secondary" aria-label="{{ 'site.search_page.pagination_orgs_aria'|trans }}">
                                {% if pageOrgs > 1 %}
                                    <a class="no-underline hover:text-text-primary hover:underline" href="{{ path('app_search_index', { q: q, type: 'all', pp: pagePersons, op: pageOrgs - 1 }) }}">{{ 'site.search_page.prev'|trans }}</a>
                                {% endif %}
                                <span>{{ 'site.search_page.page_of'|trans({ '%page%': pageOrgs, '%pages%': pagesO }) }}</span>
                                {% if pageOrgs < pagesO %}
                                    <a class="no-underline hover:text-text-primary hover:underline" href="{{ path('app_search_index', { q: q, type: 'all', pp: pagePersons, op: pageOrgs + 1 }) }}">{{ 'site.search_page.next'|trans }}</a>
                                {% endif %}
                            </nav>
                        {% endif %}
                    {% endif %}
                </section>
            </div>
        {% elseif type == 'persons' and personsResult %}
            <section class="mt-8" aria-labelledby="search-persons-only-heading">
                <h2 id="search-persons-only-heading" class="sr-only">{{ 'site.search_page.persons'|trans }}</h2>
                <p class="font-sans text-xs text-text-tertiary">{{ 'site.search_page.results_count'|trans({ '%count%': personsResult.estimatedTotalHits ?? 0 }) }}</p>
                <ul class="mt-4 divide-y divide-rule-subtle border-t border-rule-medium font-sans text-sm">
                    {% for hit in personsResult.hits %}
                        <li class="py-3">
                            <a href="{{ path('app_person_show', { slug: hit.slug }) }}" class="text-text-primary no-underline hover:text-accent hover:underline">{{ hit.fullName }}</a>
                        </li>
                    {% else %}
                        <li class="py-3 text-text-secondary">{{ 'site.search_page.no_results'|trans }}</li>
                    {% endfor %}
                </ul>
                {% set total = personsResult.estimatedTotalHits ?? 0 %}
                {% set pages = total > 0 ? ((total - 1) // perPage) + 1 : 1 %}
                {% if pages > 1 %}
                    <nav class="mt-6 flex flex-wrap gap-3 border-t border-rule-subtle pt-4 font-sans text-sm text-text-secondary" aria-label="{{ 'site.search_page.pagination_aria'|trans }}">
                        {% if page > 1 %}
                            <a class="no-underline hover:text-text-primary hover:underline" href="{{ path('app_search_index', { q: q, type: 'persons', page: page - 1 }) }}">{{ 'site.search_page.prev'|trans }}</a>
                        {% endif %}
                        <span>{{ 'site.search_page.page_of'|trans({ '%page%': page, '%pages%': pages }) }}</span>
                        {% if page < pages %}
                            <a class="no-underline hover:text-text-primary hover:underline" href="{{ path('app_search_index', { q: q, type: 'persons', page: page + 1 }) }}">{{ 'site.search_page.next'|trans }}</a>
                        {% endif %}
                    </nav>
                {% endif %}
            </section>
        {% elseif type == 'organizations' and organizationsResult %}
            <section class="mt-8" aria-labelledby="search-orgs-only-heading">
                <h2 id="search-orgs-only-heading" class="sr-only">{{ 'site.search_page.organizations'|trans }}</h2>
                <p class="font-sans text-xs text-text-tertiary">{{ 'site.search_page.results_count'|trans({ '%count%': organizationsResult.estimatedTotalHits ?? 0 }) }}</p>
                <ul class="mt-4 divide-y divide-rule-subtle border-t border-rule-medium font-sans text-sm">
                    {% for hit in organizationsResult.hits %}
                        <li class="py-3">
                            <a href="{{ path('app_organization_show', { slug: hit.slug }) }}" class="text-text-primary no-underline hover:text-accent hover:underline">{{ hit.officialName }}</a>
                        </li>
                    {% else %}
                        <li class="py-3 text-text-secondary">{{ 'site.search_page.no_results'|trans }}</li>
                    {% endfor %}
                </ul>
                {% set total = organizationsResult.estimatedTotalHits ?? 0 %}
                {% set pages = total > 0 ? ((total - 1) // perPage) + 1 : 1 %}
                {% if pages > 1 %}
                    <nav class="mt-6 flex flex-wrap gap-3 border-t border-rule-subtle pt-4 font-sans text-sm text-text-secondary" aria-label="{{ 'site.search_page.pagination_aria'|trans }}">
                        {% if page > 1 %}
                            <a class="no-underline hover:text-text-primary hover:underline" href="{{ path('app_search_index', { q: q, type: 'organizations', page: page - 1 }) }}">{{ 'site.search_page.prev'|trans }}</a>
                        {% endif %}
                        <span>{{ 'site.search_page.page_of'|trans({ '%page%': page, '%pages%': pages }) }}</span>
                        {% if page < pages %}
                            <a class="no-underline hover:text-text-primary hover:underline" href="{{ path('app_search_index', { q: q, type: 'organizations', page: page + 1 }) }}">{{ 'site.search_page.next'|trans }}</a>
                        {% endif %}
                    </nav>
                {% endif %}
            </section>
        {% endif %}
    {% endif %}
{% endblock %}
