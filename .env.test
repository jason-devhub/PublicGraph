# define your env variables for the test env here
KERNEL_CLASS='App\Kernel'
APP_SECRET='$ecretf0rt3st'
APP_DEBUG=1
APP_DEFAULT_LOCALE=en
APP_ENABLED_LOCALES=en,fr

# Même serveur que le dev Docker ; `dbname_suffix` Doctrine ajoute `_test` → base `politic_test`.
DATABASE_URL="mysql://politic:politic@db:3306/politic?serverVersion=10.11.0-MariaDB&charset=utf8mb4"

# Meilisearch : dans le conteneur app Docker → hostname `meilisearch`.
MEILISEARCH_URL=http://meilisearch:7700
MEILISEARCH_KEY=masterKey

###> symfony/panther ###
PANTHER_APP_ENV=panther
PANTHER_ERROR_SCREENSHOT_DIR=./var/error-screenshots
PANTHER_DEVTOOLS=0
###< symfony/panther ###
