# Fichier d’exemple uniquement — copier vers `.env` puis renseigner les secrets.
#   cp .env.example .env
# Les fichiers `.env`, `.env.local`, `.env.prod`, `.env.dev` sont ignorés par Git.
#
# Ordre de chargement Symfony : `.env` → `.env.local` → `.env.$APP_ENV` → `.env.$APP_ENV.local`
# https://symfony.com/doc/current/configuration.html#configuring-environment-variables-in-env-files
#
# Surcharges machine : copier les clés nécessaires vers `.env.local` (non versionné).

###> symfony/framework-bundle ###
APP_ENV=dev
APP_DEBUG=1
APP_SECRET=CHANGEME_generate_with_php_r_random_bytes_or_openssl_rand_base64
APP_SHARE_DIR=var/share
APP_DEFAULT_LOCALE=en
APP_ENABLED_LOCALES=en,fr
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> stack applicative / Docker (MariaDB et Redis fournis hors compose : Coolify ou services managés) ###
DATABASE_URL="mysql://politic:CHANGEME@CHANGEME_DB_HOST:3306/politic?serverVersion=10.11.0-MariaDB&charset=utf8mb4"
REDIS_URL=redis://CHANGEME_REDIS_HOST:6379
# Hostname = nom du service Compose `publicgraph-search`
MEILISEARCH_URL=http://publicgraph-search:7700
MEILISEARCH_KEY=CHANGEME
MAILER_DSN=null://null
###< stack applicative / Docker ###

###> docker compose (images & ports — pas de secrets applicatifs ici) ###
MAILPIT_IMAGE=axllent/mailpit
NGINX_IMAGE=nginx:1.27-alpine
NGINX_HTTP_PORT=80
MEILISEARCH_IMAGE=getmeili/meilisearch:v1.10
MEILISEARCH_HTTP_PORT=7700
MEILI_ENV=development
###< docker compose ###

###> symfony/messenger ###
MESSENGER_ASYNC_DSN=redis://CHANGEME_REDIS_HOST:6379/messages
MESSENGER_SCHEDULER_DSN=redis://CHANGEME_REDIS_HOST:6379/scheduler
###< symfony/messenger ###

###> sentry/sentry-symfony ###
SENTRY_DSN=
###< sentry/sentry-symfony ###

# -----------------------------------------------------------------------------
# Production (fichier séparé `.env.prod` : `docker compose --env-file .env.prod`)
# Copier les lignes utiles dans `.env.prod` sur le serveur — ne pas committer `.env.prod`.
# -----------------------------------------------------------------------------

# NGINX_IMAGE=nginx:1.27-alpine
# NGINX_HTTP_PORT=80
# MEILISEARCH_IMAGE=getmeili/meilisearch:v1.10
# MEILI_ENV=production
# APP_ENV=prod
# APP_DEBUG=0
# APP_SECRET=CHANGEME_generate_with_openssl_rand_hex_32
# DEFAULT_URI=https://example.org
# SYMFONY_TRUSTED_PROXIES=10.0.0.0/8,127.0.0.1
# SYMFONY_TRUSTED_HEADERS=x-forwarded-for,x-forwarded-proto,x-forwarded-port,x-forwarded-host
# STATUS_SHOW_TELEMETRY=0
# DATABASE_URL="mysql://politic:CHANGEME@CHANGEME_DB_HOST:3306/politic?serverVersion=10.11.0-MariaDB&charset=utf8mb4"
# REDIS_URL=redis://CHANGEME_REDIS_HOST:6379
# MESSENGER_ASYNC_DSN=redis://CHANGEME_REDIS_HOST:6379/messages
# MESSENGER_SCHEDULER_DSN=redis://CHANGEME_REDIS_HOST:6379/scheduler
# MAILER_DSN=null://null
